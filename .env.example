# Docker/start script env. Copy to .env and fill only what you need.
APP_PORT=3000
FRONTEND_PORT=3000
BACKEND_PORT=4000
FRONTEND_HOST=0.0.0.0
BACKEND_HOST=0.0.0.0
FRONTEND_ORIGIN=http://localhost:3000
BACKEND_CORS_ORIGINS=
BACKEND_API_BASE_URL=http://127.0.0.1:4000
NEXT_PUBLIC_BACKEND_PORT=4000
NEXT_PUBLIC_API_BASE_URL=
DOCKERFILE=Dockerfile

# Database for reports, future user profiles, and web research cache.
DATABASE_URL=
POSTGRES_PORT=5432
POSTGRES_DB=cyber_fate
POSTGRES_USER=cyber_fate
POSTGRES_PASSWORD=cyber_fate_local

# API secrets can be plaintext for local-only use, or encrypted for safer shared/server env files.
CYBER_FATE_ENV_SECRET=
PERCEPTLEAP_API_KEY=
PERCEPTLEAP_API_KEY_ENCRYPTED=
OPENAI_API_KEY=
OPENAI_API_KEY_ENCRYPTED=

CYBER_FATE_LLM_MODE=perceptleap
ENABLE_PERCEPTLEAP=true
ENABLE_PERCEPTLEAP_IMAGE=false
GENERATE_REPORT_IMAGE=false
ENABLE_OPENAI=false
ENABLE_WEB_SEARCH=true
WEB_RESEARCH_PROVIDER=searxng
WEB_RESEARCH_REQUIRED=false
WEB_RESEARCH_MIN_SOURCES=2
WEB_RESEARCH_MAX_RESULTS=20
WEB_RESEARCH_FETCH_LIMIT=12
WEB_RESEARCH_CACHE_TTL_HOURS=24
WEB_PAGE_CACHE_TTL_HOURS=168
WEB_FETCH_TIMEOUT_MS=12000
WEB_FETCH_MAX_BYTES=1500000
WEB_FETCH_MAX_CHARS=14000
WEB_FETCH_PROXY_URL=
WEB_FETCH_USER_AGENT=CyberFateResearchBot/0.1 (+local self-hosted research; respects publisher rights)
WEB_RESEARCH_COPYRIGHT_NOTICE=Online sources are used only for summary, fact checking, and citation. Do not copy long passages; respect publisher copyright and terms.
SEARXNG_PORT=8080
SEARXNG_BASE_URL=
SEARXNG_SEARCH_LANGUAGE=zh-CN

PERCEPTLEAP_BASE_URL=https://api.perceptleap.com/v1
PERCEPTLEAP_TEXT_MODEL=gpt-5.4
PERCEPTLEAP_MODEL_INTERVIEWER=
PERCEPTLEAP_MODEL_RESEARCHER=
PERCEPTLEAP_MODEL_FUSION=
PERCEPTLEAP_MODEL_COPYWRITER=
PERCEPTLEAP_MODEL_REVIEWER=
PERCEPTLEAP_MODEL_IMAGE_DIRECTOR=
PERCEPTLEAP_IMAGE_MODEL=gpt-image-2
PERCEPTLEAP_IMAGE_SIZE=1024x1024
PERCEPTLEAP_IMAGE_QUALITY=low
PERCEPTLEAP_IMAGE_OUTPUT_FORMAT=png
PERCEPTLEAP_MAX_RETRIES=2
PERCEPTLEAP_PROXY_URL=

OPENAI_MODEL_DEFAULT=
OPENAI_MODEL_INTERVIEWER=
OPENAI_MODEL_RESEARCHER=
OPENAI_MODEL_FUSION=
OPENAI_MODEL_COPYWRITER=
OPENAI_MODEL_REVIEWER=
OPENAI_MODEL_IMAGE_DIRECTOR=
OPENAI_VECTOR_STORE_ID=

APP_BASE_URL=http://localhost:3000
PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=

HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,::1
