# Server-only. Never expose this in the browser.
OPENAI_API_KEY=

# Use model names available in your OpenAI account.
OPENAI_MODEL_DEFAULT=
OPENAI_MODEL_INTERVIEWER=
OPENAI_MODEL_RESEARCHER=
OPENAI_MODEL_FUSION=
OPENAI_MODEL_COPYWRITER=
OPENAI_MODEL_REVIEWER=

# mock | openai-agents | openai-direct
CYBER_FATE_LLM_MODE=mock
ENABLE_OPENAI=false

# Research tools
ENABLE_WEB_SEARCH=false
OPENAI_VECTOR_STORE_ID=

# Used by Playwright PDF routes.
APP_BASE_URL=http://localhost:3000
