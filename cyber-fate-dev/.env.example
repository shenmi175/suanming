# Server-only. Never expose this in the browser.
OPENAI_API_KEY=

# Use model names available in your OpenAI account.
OPENAI_MODEL_DEFAULT=
OPENAI_MODEL_INTERVIEWER=
OPENAI_MODEL_RESEARCHER=
OPENAI_MODEL_FUSION=
OPENAI_MODEL_COPYWRITER=
OPENAI_MODEL_REVIEWER=

# perceptleap | openai-direct
CYBER_FATE_LLM_MODE=perceptleap
ENABLE_OPENAI=false

# PerceptLeap API mode. Use CYBER_FATE_LLM_MODE=perceptleap and ENABLE_PERCEPTLEAP=true.
PERCEPTLEAP_API_KEY=
PERCEPTLEAP_BASE_URL=https://api.perceptleap.com/v1
PERCEPTLEAP_TEXT_MODEL=gpt-5.4
PERCEPTLEAP_IMAGE_MODEL=gpt-image-2
PERCEPTLEAP_IMAGE_SIZE=1024x1024
PERCEPTLEAP_IMAGE_QUALITY=low
ENABLE_PERCEPTLEAP=true
ENABLE_PERCEPTLEAP_IMAGE=false
# Optional. Prefer this over generic proxy env when only PerceptLeap should use a proxy.
PERCEPTLEAP_PROXY_URL=

# Research tools
ENABLE_WEB_SEARCH=false
OPENAI_VECTOR_STORE_ID=

# Used by Playwright PDF routes.
APP_BASE_URL=http://localhost:3000
